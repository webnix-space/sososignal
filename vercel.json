{
  "version": 2,
  "name": "onchainedge",
  "rewrites": [
    { "source": "/api/sodex", "destination": "/api/sodex.js" },
    { "source": "/api/soso", "destination": "/api/soso.js" },
    { "source": "/api/signal", "destination": "/api/signal.js" },
    { "source": "/api/news", "destination": "/api/news.js" },
    { "source": "/api/history", "destination": "/api/history.js" },
    { "source": "/api/trade", "destination": "/api/trade.js" },
    { "source": "/api/setup", "destination": "/api/setup.js" },
    { "source": "/api/ws", "destination": "/api/ws.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/sodex",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/api/soso",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=60, stale-while-revalidate" }
      ]
    },
    {
      "source": "/api/ws",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Connection", "value": "keep-alive" }
      ]
    }
  ],
  "env": {
    "SOSO_API_KEY": "@soso_api_key",
    "GROQ_API_KEY": "@groq_api_key",
    "UPSTASH_REDIS_REST_URL": "@upstash_redis_url",
    "UPSTASH_REDIS_REST_TOKEN": "@upstash_redis_token"
  },
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}
