{
  "version": 2,
  "name": "onchainedge-wave2",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/soso",
      "dest": "/api/soso.js"
    },
    {
      "src": "/api/signal",
      "dest": "/api/signal.js"
    },
    {
      "src": "/api/sodex",
      "dest": "/api/sodex.js"
    },
    {
      "src": "/api/news",
      "dest": "/api/news.js"
    },
    {
      "src": "/api/history",
      "dest": "/api/history.js"
    },
    {
      "src": "/api/simulate",
      "dest": "/api/simulate.js"
    },
    {
      "src": "/api/trade",
      "dest": "/api/trade.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "env": {
    "SOSO_API_KEY": "@soso_api_key",
    "GROQ_API_KEY": "@groq_api_key",
    "KV_URL": "@kv_url",
    "KV_REST_API_URL": "@kv_rest_api_url",
    "KV_REST_API_TOKEN": "@kv_rest_api_token",
    "KV_REST_API_READ_ONLY_TOKEN": "@kv_rest_api_read_only_token"
  }
}
